{
  "name": "pmc-auto",
  "version": "1.0.0",
  "description": "PMC Multi-Platform E-Commerce Automation System",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "worker": "tsx src/jobs/worker.ts",
    "migrate:sheets": "tsx scripts/migrate-from-sheets.ts",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "dev:web": "cd web && npm run dev"
  },
  "keywords": [
    "ecommerce",
    "ebay",
    "shopify",
    "automation"
  ],
  "author": "inwon",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@fastify/view": "^11.1.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "eta": "^4.5.1",
    "fastify": "^5.7.4",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "patchright": "^1.57.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "xlsx": "^0.18.5"
  }
}
