<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>PMC-AUTO</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
  <link rel="stylesheet" href="/style.css?v=<%= Date.now() %>">
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script src="https://unpkg.com/htmx-ext-sse@2.2.2/sse.js"></script>
</head>
<body>
  <!-- Mobile Header -->
  <div class="mobile-header">
    <button class="mobile-menu-btn" onclick="toggleSidebar()" aria-label="메뉴 열기">
      <i class="ti ti-menu-2"></i>
    </button>
    <span class="mobile-brand">PMC-AUTO</span>
  </div>
  <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <a href="/">
        <span class="logo-icon"><i class="ti ti-package"></i></span>
        PMC-AUTO
      </a>
    </div>

    <div class="sidebar-label">메뉴</div>
    <nav class="sidebar-nav">
      <a href="/" class="nav-item <%= it.step === 0 ? 'active' : '' %>">
        <i class="ti ti-layout-dashboard"></i> 대시보드
      </a>
      <a href="/upload-csv" class="nav-item <%= it.step === 1 ? 'active' : '' %>">
        <i class="ti ti-file-upload"></i> CSV 업로드
      </a>
      <a href="/select" class="nav-item <%= it.step === 3 ? 'active' : '' %>">
        <i class="ti ti-shopping-cart"></i> 쇼핑몰 선택
      </a>
      <a href="/history" class="nav-item <%= it.step === 6 ? 'active' : '' %>">
        <i class="ti ti-history"></i> 히스토리
      </a>
      <a href="/trash" class="nav-item <%= it.step === 8 ? 'active' : '' %>">
        <i class="ti ti-trash"></i> 휴지통
      </a>
      <a href="/settings" class="nav-item <%= it.step === 7 ? 'active' : '' %>">
        <i class="ti ti-settings"></i> 설정
      </a>
    </nav>

    <% if (it.step >= 2 && it.step <= 5) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-title">진행중</div>
      <div class="sidebar-steps">
        <div class="step-item <%= it.step === 2 ? 'active' : (it.step > 2 ? 'done' : '') %>">
          <i class="ti ti-<%= it.step > 2 ? 'circle-check' : (it.step === 2 ? 'loader' : 'circle') %>"></i>
          1. 등록
        </div>
        <div class="step-item <%= it.step === 3 ? 'active' : (it.step > 3 ? 'done' : '') %>">
          <i class="ti ti-<%= it.step > 3 ? 'circle-check' : (it.step === 3 ? 'loader' : 'circle') %>"></i>
          2. 선택
        </div>
        <div class="step-item <%= it.step === 4 ? 'active' : (it.step > 4 ? 'done' : '') %>">
          <i class="ti ti-<%= it.step > 4 ? 'circle-check' : (it.step === 4 ? 'loader' : 'circle') %>"></i>
          3. 업로드
        </div>
        <div class="step-item <%= it.step === 5 ? 'active' : '' %>">
          <i class="ti ti-<%= it.step === 5 ? 'loader' : 'circle' %>"></i>
          4. 결과
        </div>
      </div>
    </div>
    <% } %>

    <div class="sidebar-footer">
      <div class="sidebar-user" id="sidebar-user" onclick="showNameModal()">
        <div class="sidebar-user-avatar" id="user-avatar">?</div>
        <div class="sidebar-user-info">
          <span class="sidebar-user-name" id="user-name-display">설정 안됨</span>
          <span class="sidebar-user-role" id="user-role-badge"></span>
        </div>
        <i class="ti ti-pencil sidebar-user-edit"></i>
      </div>
      <div class="sidebar-footer-text">
        <i class="ti ti-code"></i> PMC Auto v1.0
      </div>
    </div>
  </aside>

  <!-- 닉네임 설정 모달 -->
  <div class="modal-overlay" id="name-modal">
    <div class="modal-card">
      <div class="modal-icon">
        <i class="ti ti-user-circle"></i>
      </div>
      <h3 class="modal-title">안녕하세요!</h3>
      <p class="modal-desc">원활한 팀 협업을 위해 사용하실 이름을 알려주세요.<br>다른 팀원들에게 표시됩니다.</p>
      <input type="text" id="name-input" class="modal-input" placeholder="이름을 입력해 주세요" maxlength="20">
      <label class="modal-checkbox" id="admin-check-label">
        <input type="checkbox" id="admin-check" onchange="toggleAdminField()">
        <span>관리자로 로그인</span>
      </label>
      <div class="modal-admin-field" id="admin-field" style="display:none;">
        <input type="password" id="admin-password" class="modal-input" placeholder="관리자 비밀번호를 입력해 주세요">
      </div>
      <div class="modal-actions">
        <button id="name-cancel-btn" class="btn btn-secondary" onclick="hideNameModal()">취소</button>
        <button class="btn btn-primary" onclick="saveName()"><i class="ti ti-check"></i> 확인</button>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <main class="main-content">
    <%~ it.body %>
  </main>

  <!-- Toast Container -->
  <div class="toast-container" id="toast-container"></div>

  <script>
  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebar-overlay').classList.toggle('active');
  }

  // ── 사용자 세션 관리 ──
  function getTeamUser() {
    try {
      const raw = document.cookie.split('; ').find(c => c.startsWith('team_user='));
      if (!raw) return null;
      return JSON.parse(decodeURIComponent(raw.split('=').slice(1).join('=')));
    } catch { return null; }
  }

  function updateUserDisplay() {
    const user = getTeamUser();
    const nameEl = document.getElementById('user-name-display');
    const badgeEl = document.getElementById('user-role-badge');
    const avatarEl = document.getElementById('user-avatar');
    const userEl = document.getElementById('sidebar-user');

    if (user && user.name) {
      nameEl.textContent = user.name;
      avatarEl.textContent = user.name.charAt(0).toUpperCase();
      userEl.classList.add('active');
      fetch('/api/user/me').then(r => r.json()).then(data => {
        if (data.user?.isAdmin) {
          badgeEl.textContent = 'Admin';
          badgeEl.className = 'sidebar-user-role role-admin';
        } else {
          badgeEl.textContent = '팀원';
          badgeEl.className = 'sidebar-user-role role-member';
        }
      }).catch(() => {});
    } else {
      nameEl.textContent = '이름을 설정해 주세요';
      avatarEl.textContent = '?';
      badgeEl.className = 'sidebar-user-role';
      badgeEl.textContent = '';
      userEl.classList.remove('active');
    }
  }

  function toggleAdminField() {
    const checked = document.getElementById('admin-check').checked;
    const field = document.getElementById('admin-field');
    field.style.display = checked ? '' : 'none';
    if (checked) {
      setTimeout(() => document.getElementById('admin-password').focus(), 50);
    }
  }

  function showNameModal() {
    const modal = document.getElementById('name-modal');
    const input = document.getElementById('name-input');
    const cancelBtn = document.getElementById('name-cancel-btn');
    const adminCheck = document.getElementById('admin-check');
    const adminField = document.getElementById('admin-field');
    const adminPw = document.getElementById('admin-password');
    const user = getTeamUser();
    if (user?.name) {
      input.value = user.name;
      cancelBtn.style.display = '';
    } else {
      input.value = '';
      cancelBtn.style.display = 'none';
    }
    // Admin 필드 초기화
    adminCheck.checked = false;
    adminField.style.display = 'none';
    adminPw.value = '';
    modal.classList.add('visible');
    setTimeout(() => input.focus(), 100);
  }

  function hideNameModal() {
    document.getElementById('name-modal').classList.remove('visible');
  }

  async function saveName() {
    const name = document.getElementById('name-input').value.trim();
    if (!name) return;

    const wantAdmin = document.getElementById('admin-check').checked;
    const adminPassword = document.getElementById('admin-password').value;

    // Admin 체크했는데 비밀번호 미입력
    if (wantAdmin && !adminPassword) {
      showToast('관리자 비밀번호를 입력해 주세요.', 'error');
      document.getElementById('admin-password').focus();
      return;
    }

    try {
      // 1) Admin 인증 (체크된 경우)
      if (wantAdmin) {
        const authRes = await fetch('/api/settings/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: adminPassword }),
        });
        const authData = await authRes.json();
        if (authData.error) {
          showToast('관리자 비밀번호가 올바르지 않습니다.', 'error');
          document.getElementById('admin-password').focus();
          return;
        }
      }

      // 2) 이름 설정
      const res = await fetch('/api/user/set-name', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, asAdmin: wantAdmin }),
      });
      const data = await res.json();
      if (data.error) {
        showToast(data.error, 'error');
        return;
      }
      hideNameModal();
      updateUserDisplay();
      const greeting = wantAdmin ? name + '님, 관리자로 로그인되었습니다!' : name + '님, 환영합니다!';
      showToast(greeting, 'success');
    } catch (e) {
      showToast('이름 설정에 실패했습니다. 다시 시도해 주세요.', 'error');
    }
  }

  // 페이지 로드 시 닉네임 확인
  document.addEventListener('DOMContentLoaded', () => {
    updateUserDisplay();
    const user = getTeamUser();
    if (!user || !user.name) {
      showNameModal();
    }
  });

  function showToast(message, type = 'info') {
    const container = document.getElementById('toast-container');
    const icons = { success: 'circle-check', error: 'alert-circle', info: 'info-circle' };
    const toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.innerHTML = '<i class="ti ti-' + icons[type] + '"></i><span>' + message + '</span>' +
      '<button class="toast-close" onclick="this.parentElement.remove()"><i class="ti ti-x"></i></button>';
    container.appendChild(toast);
    setTimeout(() => { if (toast.parentElement) toast.remove(); }, 4000);
  }
  </script>
</body>
</html>
