<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>PMC-AUTO</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="preconnect" href="https://unpkg.com" crossorigin>
  <link rel="stylesheet" href="/style.css?v=<%= Date.now() %>">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" media="print" onload="this.media='all'">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" media="print" onload="this.media='all'">
  <script defer src="https://unpkg.com/htmx.org@2.0.4"></script>
  <script defer src="https://unpkg.com/htmx-ext-sse@2.2.2/sse.js"></script>
</head>
<body>
  <!-- Mobile Header -->
  <div class="mobile-header">
    <button class="mobile-menu-btn" onclick="toggleSidebar()" aria-label="메뉴 열기">
      <i class="ti ti-menu-2"></i>
    </button>
    <span class="mobile-brand">PMC-AUTO</span>
  </div>
  <div class="sidebar-overlay" id="sidebar-overlay" onclick="toggleSidebar()"></div>

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <a href="/">
        <span class="logo-icon"><i class="ti ti-package"></i></span>
        PMC-AUTO
      </a>
    </div>

    <div class="sidebar-label">상품</div>
    <nav class="sidebar-nav">
      <a href="/" class="nav-item <%= it.step === 0 ? 'active' : '' %>">
        <i class="ti ti-package"></i> 상품 관리
      </a>
      <a href="/upload-csv" class="nav-item <%= it.step === 1 ? 'active' : '' %>">
        <i class="ti ti-file-upload"></i> CSV 업로드
      </a>
      <a href="/history" class="nav-item <%= it.step === 6 ? 'active' : '' %>">
        <i class="ti ti-history"></i> 히스토리
      </a>
      <a href="/trash" class="nav-item <%= it.step === 8 ? 'active' : '' %>">
        <i class="ti ti-trash"></i> 휴지통
      </a>
    </nav>

    <div class="sidebar-label admin-only">관리</div>
    <nav class="sidebar-nav admin-only">
      <a href="/settings" class="nav-item <%= it.step === 7 ? 'active' : '' %>">
        <i class="ti ti-settings"></i> 설정
      </a>
      <a href="/tokens" class="nav-item <%= it.step === 9 ? 'active' : '' %>">
        <i class="ti ti-key"></i> 토큰 관리
      </a>
      <a href="/staff" class="nav-item <%= it.step === 11 ? 'active' : '' %>">
        <i class="ti ti-users-group"></i> 직원 관리
      </a>
      <a href="/audit" class="nav-item <%= it.step === 12 ? 'active' : '' %>">
        <i class="ti ti-report-analytics"></i> 작업 로그
      </a>
      <a href="/backups" class="nav-item <%= it.step === 13 ? 'active' : '' %>">
        <i class="ti ti-database-export"></i> DB 백업
      </a>
    </nav>

    <div class="sidebar-label">도움말</div>
    <nav class="sidebar-nav">
      <a href="/manual" class="nav-item <%= it.step === 20 ? 'active' : '' %>">
        <i class="ti ti-book"></i> 사용설명서
      </a>
    </nav>

    <% if (it.step >= 2 && it.step <= 5) { %>
    <div class="sidebar-section">
      <div class="sidebar-section-title">진행중</div>
      <div class="sidebar-steps">
        <div class="step-item <%= it.step === 2 ? 'active' : (it.step > 2 ? 'done' : '') %>">
          <i class="ti ti-<%= it.step > 2 ? 'circle-check' : (it.step === 2 ? 'loader' : 'circle') %>"></i>
          1. 등록
        </div>
        <div class="step-item <%= it.step === 3 ? 'active' : (it.step > 3 ? 'done' : '') %>">
          <i class="ti ti-<%= it.step > 3 ? 'circle-check' : (it.step === 3 ? 'loader' : 'circle') %>"></i>
          2. 선택
        </div>
        <div class="step-item <%= it.step === 4 ? 'active' : (it.step > 4 ? 'done' : '') %>">
          <i class="ti ti-<%= it.step > 4 ? 'circle-check' : (it.step === 4 ? 'loader' : 'circle') %>"></i>
          3. 업로드
        </div>
        <div class="step-item <%= it.step === 5 ? 'active' : '' %>">
          <i class="ti ti-<%= it.step === 5 ? 'loader' : 'circle' %>"></i>
          4. 결과
        </div>
      </div>
    </div>
    <% } %>

    <div class="sidebar-footer">
      <div class="sidebar-user" id="sidebar-user">
        <div class="sidebar-user-avatar" id="user-avatar">?</div>
        <div class="sidebar-user-info">
          <span class="sidebar-user-name" id="user-name-display">로딩 중...</span>
          <span class="sidebar-user-role" id="user-role-badge"></span>
        </div>
        <button class="sidebar-user-edit" onclick="handleLogout()" title="로그아웃" style="background:none;border:none;cursor:pointer;color:var(--text-muted);padding:4px;">
          <i class="ti ti-logout"></i>
        </button>
      </div>
      <div class="sidebar-footer-text">
        <i class="ti ti-code"></i> PMC Auto v1.0
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <%~ it.body %>
  </main>

  <!-- Toast Container -->
  <div class="toast-container" id="toast-container"></div>

  <script>
  function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebar-overlay').classList.toggle('active');
  }

  // ── 사용자 표시 ──
  function updateUserDisplay() {
    fetch('/api/auth/me').then(r => r.json()).then(data => {
      const nameEl = document.getElementById('user-name-display');
      const badgeEl = document.getElementById('user-role-badge');
      const avatarEl = document.getElementById('user-avatar');
      const userEl = document.getElementById('sidebar-user');

      if (data.user) {
        nameEl.textContent = data.user.displayName;
        avatarEl.textContent = data.user.displayName.charAt(0).toUpperCase();
        userEl.classList.add('active');

        if (data.user.role === 'admin') {
          badgeEl.textContent = 'Admin';
          badgeEl.className = 'sidebar-user-role role-admin';
          document.querySelectorAll('.admin-only').forEach(el => el.classList.add('visible'));
        } else {
          badgeEl.textContent = 'Staff';
          badgeEl.className = 'sidebar-user-role role-member';
        }
      }
    }).catch(() => {});
  }

  async function handleLogout() {
    if (!confirm('로그아웃 하시겠습니까?')) return;
    try {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/login';
    } catch {
      window.location.href = '/login';
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateUserDisplay();
  });

  function showToast(message, type = 'info') {
    const container = document.getElementById('toast-container');
    const icons = { success: 'circle-check', error: 'alert-circle', info: 'info-circle' };
    const toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.innerHTML = '<i class="ti ti-' + icons[type] + '"></i><span>' + message + '</span>' +
      '<button class="toast-close" onclick="this.parentElement.remove()"><i class="ti ti-x"></i></button>';
    container.appendChild(toast);
    setTimeout(() => { if (toast.parentElement) toast.remove(); }, 4000);
  }
  </script>
</body>
</html>
