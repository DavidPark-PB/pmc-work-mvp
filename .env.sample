# Shopify API Credentials
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_STORE=your-store
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01
SHOPIFY_LOCATION_ID=

# eBay API Credentials (Production)
EBAY_APP_ID=your-ebay-app-id
EBAY_DEV_ID=your-ebay-dev-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_USER_TOKEN=your-ebay-user-token
EBAY_REFRESH_TOKEN=your-ebay-refresh-token
EBAY_RUNAME=your-ebay-runame
EBAY_ENVIRONMENT=PRODUCTION

# Google Sheets
GOOGLE_SPREADSHEET_ID=your-google-spreadsheet-id

# ── Alibaba (ICBU) ────────────────────────────
ALIBABA_APP_KEY=your-alibaba-app-key
ALIBABA_APP_SECRET=your-alibaba-app-secret
ALIBABA_ACCESS_TOKEN=your-alibaba-access-token
ALIBABA_REFRESH_TOKEN=your-alibaba-refresh-token
ALIBABA_PLATFORM=international

# ── Shopee ─────────────────────────────────────
SHOPEE_PARTNER_ID=your-shopee-partner-id
SHOPEE_PARTNER_KEY=your-shopee-partner-key
SHOPEE_SHOP_ID=your-shopee-shop-id
SHOPEE_MERCHANT_ID=your-shopee-merchant-id
SHOPEE_ACCESS_TOKEN=your-shopee-access-token
SHOPEE_REFRESH_TOKEN=your-shopee-refresh-token
SHOPEE_ENV=test

# ── Qoo10 Japan (추후 입력) ──────────────────
# QOO10_API_KEY=
# QOO10_USER_ID=
# QOO10_USER_PASSWORD=

# ── 쿠팡 (추후 입력) ─────────────────────────
