# ============================================
# PMC Work MVP - 환경 변수 설정
# 이 파일을 .env로 복사하고 실제 값을 입력하세요
# cp .env.example .env
# ============================================

# Google Sheets
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Service Account 자격증명 (택1)
#   1) 로컬 dev / fly.io: config/credentials.json 파일 사용 (gitignored)
#   2) Railway 등 파일 마운트 안 되는 호스팅: 아래 env 에 JSON 한 줄로 붙여넣기
# GOOGLE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}'
GOOGLE_CREDENTIALS_JSON=

# ── 카탈로그 가격 관리 (3시트 동시 미러링) ────
# 미설정 시 코드 기본값 사용
SHEET_ID_USD=1O6a7tSHmIHiFSmX0qLXN7Ab624viR-sEENmrGtXfQ_0
SHEET_ID_KRW=1cw9ss_mImxeQes4OF0hRop5iQ2r0B5YjKYBiZIz2MHY
SHEET_ID_EURO=1h_96W_dnQsfof2Ain4Jdpur4z7q-0h3yeMR_5442spw

# 환차익 마진 — 시장환율에서 차감해서 지정환율로 사용
# KRW 기본 50원, EUR 기본 0.03€ (약 3.3% 쿠션)
FX_MARGIN_KRW=50
FX_MARGIN_EUR=0.03

# ── Shopify ──────────────────────────────────
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# ── eBay ─────────────────────────────────────
EBAY_APP_ID=your_app_id
EBAY_CERT_ID=your_cert_id
EBAY_DEV_ID=your_dev_id
EBAY_USER_TOKEN=your_user_token
EBAY_ENVIRONMENT=PRODUCTION

# ── Alibaba ──────────────────────────────────
ALIBABA_APP_KEY=your_alibaba_app_key
ALIBABA_APP_SECRET=your_alibaba_app_secret
ALIBABA_ACCESS_TOKEN=your_alibaba_access_token
ALIBABA_PLATFORM=international

# ── Shopee ───────────────────────────────────
SHOPEE_PARTNER_ID=your_partner_id
SHOPEE_PARTNER_KEY=your_partner_key
SHOPEE_SHOP_ID=your_shop_id
SHOPEE_ACCESS_TOKEN=your_shopee_access_token
SHOPEE_REFRESH_TOKEN=your_shopee_refresh_token
SHOPEE_ENV=production

# ── Qoo10 Japan ──────────────────────────────
QOO10_API_KEY=your_qoo10_api_key
QOO10_USER_ID=your_qoo10_user_id
QOO10_USER_PASSWORD=your_qoo10_password

# ── 쿠팡 (추후 추가) ─────────────────────────
# COUPANG_ACCESS_KEY=
# COUPANG_SECRET_KEY=
# COUPANG_VENDOR_ID=

# ── 네이버 스마트스토어 (추후 추가) ───────────
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# NAVER_COMMERCE_ID=

# ── Supabase ────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── DB Migration Flags ──────────────────────
# 'sheets' = Google Sheets (default), 'supabase' = Supabase DB
DB_SOURCE=sheets
# Set to 'true' to write to both Sheets and Supabase during migration
DB_DUAL_WRITE=false

# ── Telegram Bot (Agent Alerts) ───────────────
# 1. Message @BotFather → /newbot → copy token
# 2. Add bot to group → send message → get chat_id from getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── iMessage (macOS only, Agent Alerts) ───────
# Phone number (+82-10-xxxx-xxxx) or Apple ID email
IMESSAGE_TO=

# ── Accio Gateway (로컬 dev 전용 - AI 이미지 생성 · Junglescout) ──
# Accio Desktop 앱이 실행되는 머신에서만 true 로 설정. Fly.io 프로덕션은 false.
ACCIO_ENABLED=false
ACCIO_BASE_URL=http://127.0.0.1:4097

# ── 우체국 (Korea Post) Open API ──
# biz.epost.go.kr → 오픈API 신청 → 인증키 발급 후 입력.
# 신청된 3개 API: EMS/K-Packet 요금조회 + 종추적 + 소포신청 (라벨 발급).
# Endpoint URL 은 매뉴얼 기본값 박혀있어서 비워두면 자동 사용.
KOREAPOST_API_KEY=
KOREAPOST_CUSTNO=                  # 고객번호 (예: 0005077976)
KOREAPOST_APPRNO_KPACKET=          # K-Packet 계약승인번호 (예: 40139J1076)
KOREAPOST_APPRNO_EMS=              # EMS 계약국제특급 계약승인번호 (예: 40139H1226)
KOREAPOST_PREMIUMCD=14             # 서비스 프리미엄 코드 (매뉴얼 확인)
KOREAPOST_RATE_URL=                # 비우면 eship.epost.go.kr/api/EmsTotProcCmd.ems
KOREAPOST_TRACK_URL=               # 비우면 biz.epost.go.kr/KpostPortal/openapi
KOREAPOST_LABEL_URL=               # 매뉴얼 확인 후 입력 (소포신청 endpoint)
KOREAPOST_SHIPPER_NAME=PMC Corporation
KOREAPOST_SHIPPER_TEL=
KOREAPOST_SHIPPER_ZIP=
KOREAPOST_SHIPPER_ADDR=

# ── FedEx API (B2B 자동 배송비 계산 + 라벨 생성) ──
# FedEx Developer Portal: https://developer.fedex.com → Create App → Production/Sandbox 키 발급
# Sandbox 먼저 검증 후 FEDEX_API_BASE 만 https://apis.fedex.com 으로 전환.
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT_NUMBER=
FEDEX_API_BASE=https://apis-sandbox.fedex.com
# 출발지 = 한국 창고 (KR). 모든 발송 international export.
FEDEX_ORIGIN_NAME=PMC Corporation
FEDEX_ORIGIN_PHONE=+82-XX-XXXX-XXXX
FEDEX_ORIGIN_STREET=
FEDEX_ORIGIN_CITY=Seoul
FEDEX_ORIGIN_STATE=
FEDEX_ORIGIN_ZIP=
FEDEX_ORIGIN_COUNTRY=KR
